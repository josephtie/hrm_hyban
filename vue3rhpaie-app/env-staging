# Configuration pour l'environnement de staging/test
# Utilisez cette configuration pour les tests d'intégration

# Configuration API Backend
VITE_API_BASE_URL=https://staging-api.hyban.com
VITE_API_PORT=443
VITE_API_TIMEOUT=30000

# Configuration Keycloak
VITE_KEYCLOAK_URL=https://staging-auth.hyban.com
VITE_KEYCLOAK_PORT=443
VITE_KEYCLOAK_REALM=hyban
VITE_KEYCLOAK_CLIENT_ID=hrm_frontend
VITE_KEYCLOAK_GRANT_TYPE=password
VITE_KEYCLOAK_SCOPE=openid profile email

# Configuration de l'application
VITE_APP_NAME=HRM Hyban - Staging
VITE_APP_VERSION=1.0.0-staging
VITE_APP_DEBUG=false

# Configuration des environnements
NODE_ENV=staging
VITE_NODE_ENV=staging
